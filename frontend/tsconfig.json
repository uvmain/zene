{
  "compilerOptions": {
    "composite": true,
    "target": "esnext",
    "lib": ["esnext", "DOM"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "~/*": ["./src/*"]
    },
    "types": [
      "node",
      "vite/client"
    ],
    "strict": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "vite.config.ts",
    "uno.config.ts",
    "components.d.ts",
    "auto-imports.d.ts",
    "./route-map.d.ts",
    "types/*.d.ts",
    "src/**/*"
  ],
  "exclude": ["node_modules", "dist", "eslint.config.js"],
  "vueCompilerOptions": {
    "plugins": [
      "vue-router/volar/sfc-typed-router",
      "vue-router/volar/sfc-route-blocks"
    ]
  }
}
